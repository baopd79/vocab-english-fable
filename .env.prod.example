# Production env — copy to .env.prod (gitignored, NEVER commit the real one).
# Used two ways: `--env-file .env.prod` interpolates ${VAR} in the compose
# file (db credentials, build args); `env_file: .env.prod` feeds backend/worker.

# ===== Django =====
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=generate-a-long-random-string
# 127.0.0.1 is required — the container healthcheck calls the API directly.
# Local prod test: ALLOWED_HOSTS=localhost,127.0.0.1
ALLOWED_HOSTS=yourdomain.com,127.0.0.1

# ===== Postgres (compose network: host is the service name "db") =====
POSTGRES_DB=vocab
POSTGRES_USER=vocab
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://vocab:change-me-strong-password@db:5432/vocab

# ===== Redis (service name "redis") =====
REDIS_URL=redis://redis:6379/0

# ===== AI =====
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_DAILY_BUDGET=18
ENRICHMENT_RATE_LIMIT=4/m

# ===== Google OAuth =====
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Build-time only (docker compose build): inlined into the Next.js bundle.
# The domain must be added to the OAuth client's Authorized JavaScript origins.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
